# ================================
# WazobiCare Nigeria — Environment Variables
# ================================
# Copy this file to .env.local and fill in real values

# PostgreSQL — Neon Database
# Get from: https://console.neon.tech → Your Project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Google Gemini AI
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# UploadThing — File Storage
# Get from: https://uploadthing.com → Dashboard → Your App → API Keys
UPLOADTHING_SECRET=sk_live_your_secret
UPLOADTHING_APP_ID=your_app_id
UPLOADTHING_TOKEN=your_token

# Facebook MMS TTS — Self-hosted Python server
# URL of your MMS TTS server (default: http://localhost:8001)
MMS_TTS_API_URL=http://localhost:8001
