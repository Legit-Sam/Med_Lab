# ================================
# WazobiCare Nigeria — Environment Variables
# ================================
# Copy this file to .env.local and fill in real values

# Clerk Authentication
# Get from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# PostgreSQL — Neon Database
# Get from: https://console.neon.tech → Your Project → Connection string
# Select "Pooled connection" for best Vercel performance
DATABASE_URL=postgresql://user:password@ep-example-123.us-east-2.aws.neon.tech/neondb?sslmode=require

# Google Gemini AI
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_YOUR_KEY_HERE

# ElevenLabs Text-to-Speech
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE
# Optional: use one multilingual voice for Yoruba, Hausa, and Igbo.
# Defaults to ElevenLabs' example voice if omitted.
ELEVENLABS_MULTILINGUAL_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# UploadThing — File Storage
# Get from: https://uploadthing.com → Dashboard → Your App → API Keys
UPLOADTHING_TOKEN=YOUR_UPLOADTHING_TOKEN_HERE
